<?xml version="1.0" encoding="UTF-8" ?>
<schema name="shop-bilingual-schema" version="1.6">

    <uniqueKey>id</uniqueKey>

    <fieldType name="string" class="solr.StrField" sortMissingLast="true" />
    <fieldType name="pint" class="solr.IntPointField" docValues="true"/>
    <fieldType name="plong" class="solr.LongPointField" docValues="true"/>

    <fieldType name="text_de" class="solr.TextField" positionIncrementGap="100">
        <analyzer>
            <tokenizer class="solr.StandardTokenizerFactory"/>
            <filter class="solr.LowerCaseFilterFactory"/>
            <filter class="solr.GermanLightStemFilterFactory"/>
            <filter class="solr.GermanNormalizationFilterFactory"/>
        </analyzer>
    </fieldType>

    <fieldType name="text_en" class="solr.TextField" positionIncrementGap="100">
        <analyzer>
            <tokenizer class="solr.StandardTokenizerFactory"/>
            <filter class="solr.LowerCaseFilterFactory"/>
            <filter class="solr.EnglishMinimalStemFilterFactory"/>
        </analyzer>
    </fieldType>

    <field name="id" type="string" indexed="true" stored="true" required="true" />
    <field name="product_id" type="pint" indexed="true" stored="true" required="true" />
    <field name="description_de" type="text_de" indexed="true" stored="true" />
    <field name="description_en" type="text_en" indexed="true" stored="true" />
    <field name="_version_" type="plong" indexed="false" stored="false"/>

</schema>